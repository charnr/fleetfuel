sign_off, deposit, gip, cohort_country&#13;
from mi_portfolio_metrics&#13;
where cohort_account_type = &apos;PAYGO&apos;</relation>
          </relation>
          <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc' name='Vol' type='text'>SELECT * FROM (&#13;
select  sum(quantity) as Volume, cust_surr_id, iso_week, product_name,iso_no&#13;
from ext_sources.transactions_fuel_with_costs&#13;
where deleted_date is null&#13;
and iso_week &gt;&gt;= &apos;202514&apos;&#13;
and product_name IN(&apos;AD BLUE&apos;,&apos;DIESEL&apos;, &apos;UNLEADED&apos;, &apos;PREMIUM DIESEL&apos;,&#13;
&apos;PREMIUM UNLEADED&apos;, &apos;SUPER UNLEADED&apos;, &apos;LPG&apos;, &apos;HVO&apos;, &apos;BIO DIESEL&apos;,&apos;LNG&apos;,&apos;LRP&apos;, &apos;ELECTRIC CHARGING (KW/H)&apos;, &apos;E-CHARGE FAST&apos;, &apos;E-CHARGE RAPID&apos;, &apos;E-CHARGE ULTRAFAST&apos;)&#13;
group by cust_surr_id, iso_week, product_name, iso_no&#13;
) tfwc&#13;
LEFT OUTER JOIN (&#13;
	SELECT caldate, isowk::VARCHAR FROM calendar where DATE_PART(&apos;dow&apos;, caldate)= 6&#13;
) a  ON tfwc.iso_week = a.isowk</relation>
        </relation>
