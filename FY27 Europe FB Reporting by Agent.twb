    <worksheet name='FY27 - Accounts'>
      <table>
        <view>
          <datasources>
            <datasource caption='ER &amp; NB' name='federated.0o9538t0mqnncq1elzj5212ja7ec (copy)' />
          </datasources>
          <datasource-dependencies datasource='federated.0o9538t0mqnncq1elzj5212ja7ec (copy)'>
            <column caption='New Buyers' datatype='integer' name='[Calculation_1003739781612056576]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [iso_week] = [first_trans_week] THEN 1 ELSE 0 END' />
            </column>
            <column caption='OSW' datatype='integer' name='[Calculation_1003739781620453378]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[start_date (Custom SQL Query)])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#,[start_date (Custom SQL Query)])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date (Custom SQL Query)])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
            </column>
            <column caption='Account Status (Fuel)' datatype='integer' name='[Calculation_2081788987459231764]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [fuel_live_account] = &apos;TRUE&apos; THEN 1&#13;&#10;ELSEIF [fuel_live_account] = &apos;FALSE&apos; THEN 0&#13;&#10;END' />
            </column>
            <column caption='Neverdrawn' datatype='integer' name='[Calculation_2081788987459293205]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF INT([first_trans_week]) = 0 &#13;&#10;OR INT([first_trans_week]) &gt; INT([iso_week]) &#13;&#10;THEN 1 ELSE 0 END' />
            </column>
            <column caption='New Buyers within 4 wks' datatype='integer' name='[Calculation_2081788987459731479]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1003739781612056576]=1 AND DATEDIFF(&apos;day&apos;,[start_date (Custom SQL Query)],[first_trans_date])&lt;=28&#13;&#10;THEN 1 ELSE 0 END' />
            </column>
            <column caption='Accounts Created' datatype='integer' name='[Calculation_2147935580813082631]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1003739781620453378] = int([iso_week]) THEN 1 ELSE 0 END' />
            </column>
            <column caption='New Buyers to Start Week' datatype='integer' name='[Calculation_2147935580815921161]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [surr_id],[iso_week]: MAX(IF [Calculation_2147935580813082631]=1 AND ({ EXCLUDE [iso_week]:SUM([volume])})&gt;0 THEN 1 END)}' />
            </column>
            <column caption='Active Cards In Week' datatype='integer' name='[active_cards_in_week]' role='dimension' type='quantitative' />
