      <column caption='Volume From' datatype='date' name='[Calculation_185210593375223814]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISNULL([end_date]) THEN TODAY() ELSE DATE([end_date]) END' />
      </column>
      <column caption='Applied for Petrol LOD' datatype='integer' name='[Calculation_2081788987453059073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2147935580801040384] :MAX([monthly_petrol])}' />
      </column>
      <column caption='Applied for Diesel LOD' datatype='integer' name='[Calculation_2081788987453132802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2147935580801040384] :MAX([monthly_diesel])}' />
      </column>
      <column caption='VIC' datatype='integer' name='[Calculation_2081788987453235203]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2081788987453132802]+[Calculation_2081788987453059073]' />
      </column>
      <column caption='Drawers' datatype='real' name='[Calculation_2081788987453919237]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [sum_quantity_to_date] &gt; 0 then [surr_id] else null end' />
      </column>
      <column caption='Drawers Fix' datatype='real' name='[Calculation_2081788987454255111]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if NOT ISNULL([Calculation_2081788987453919237]) then [Calculation_2081788987453919237] END' />
      </column>
      <column caption='Max NCM' datatype='integer' name='[Calculation_2081788987454959624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id] : MAX([ncm])}' />
      </column>
      <column caption='Max Deposit Limit' datatype='integer' name='[Calculation_2081788987455057929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id] : MAX([deposit_limit])}' />
      </column>
      <column caption='Net Fuel Price' datatype='real' name='[Calculation_2081788987455135754]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id] : MAX(IF [country] = &apos;GB&apos;THEN 1.5&#13;&#10;ELSEIF [country] = &apos;IE&apos; THEN 1.5&#13;&#10;ELSEIF [country] = &apos;NL&apos; THEN 1.7&#13;&#10;ELSEIF [country] = &apos;BE&apos; THEN 1.7&#13;&#10;ELSEIF [country] = &apos;FR&apos; THEN 1.9&#13;&#10;ELSEIF [country] = &apos;PT&apos; then 1.9   &#13;&#10;ELSEIF [country] = &apos;ES&apos; THEN 2.1&#13;&#10;ELSEIF [country] = &apos;DE&apos; THEN 1.8&#13;&#10;ELSEIF [country] = &apos;IT&apos; THEN 2&#13;&#10;ELSEIF [country] = &apos;MY&apos; THEN 2.5&#13;&#10;ELSEIF [country] = &apos;SG&apos; THEN 1.8&#13;&#10;ELSE 0&#13;&#10;END)}' />
      </column>
      <column caption='Max Paycode Weeks Exposure' datatype='integer' name='[Calculation_2081788987455328267]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id] : MAX([paycode_weeks_exposure])}' />
      </column>
      <column caption='Max given fuel limit' datatype='integer' name='[Calculation_2081788987455389708]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id]: MAX([given_fuel_limit])}' />
      </column>
      <column caption='VOC New' datatype='real' name='[Calculation_2081788987455430669]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id]: MAX(IF [underwriting_type] =&apos;External Insurance&apos; THEN  (IFNULL([Calculation_2081788987454959624],0)+ IFNULL([Calculation_2081788987455057929],0)) / [Calculation_2081788987455135754] / [Calculation_2081788987455328267] * 4.33 &#13;&#10;ELSE (IFNULL([Calculation_2081788987455389708],0)+ IFNULL([Calculation_2081788987455057929],0)) / [Calculation_2081788987455135754] / [Calculation_2081788987455328267] * 4.33&#13;&#10;END)}' />
      </column>
      <column caption='Unique App' datatype='string' name='[Calculation_2147935580801040384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([external_lead_id]) THEN [app_id] &#13;&#10;ELSE [external_lead_id] END' />
      </column>
      <column caption='App Completed ISOWeek' datatype='integer' name='[Calculation_2147935580801355777]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[date_app_completed])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [date_app_completed])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [date_app_completed])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column aggregation='Sum' caption='Employee Start Week' datatype='integer' name='[Calculation_942941209350447104]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[start_date])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
