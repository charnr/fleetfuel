      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0o9538t0mqnncq1elzj5212ja7ec (copy)].[ctd:surr_id (Custom SQL Query):qk]&quot;' value='Customers' />
        </aliases>
      </column>
      <column caption='New Buyers' datatype='integer' name='[Calculation_1003739781612056576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [iso_week] = [first_trans_week] THEN 1 ELSE 0 END' />
      </column>
      <column caption='OSW' datatype='integer' name='[Calculation_1003739781620453378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[start_date (Custom SQL Query)])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#,[start_date (Custom SQL Query)])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date (Custom SQL Query)])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='Cohort (Rolling)' datatype='string' name='[Calculation_1003739781620506627]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1003739781620453378] &gt; INT([bb_transfer_week]) THEN&#13;&#10;    &apos;1st Yr/FB&apos;&#13;&#10;ELSE &apos;2nd Yr/BB&apos;&#13;&#10;END' />
      </column>
      <column caption='Ireland Incentive Manager Fix' datatype='string' name='[Calculation_1103100487063879680]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [name] IN (&apos;David Monaghan&apos;,&apos;Andrin Kraja&apos;) THEN &apos;Sales IB&apos; ELSE [team] END' />
      </column>
      <column caption='Incentive Team' datatype='string' name='[Calculation_1103100487064567809]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[office_location (team_member) - Split 2] + &quot; &quot; + [Calculation_1103100487063879680]' />
      </column>
      <column caption='Volume From' datatype='date' name='[Calculation_185210593375223814]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISNULL([end_date]) THEN TODAY() ELSE DATE([end_date]) END' />
      </column>
      <column caption='Rolling 1Yr' datatype='string' name='[Calculation_185210593375666184]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date (Custom SQL Query)]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-52,[Calculation_185210593375223814]))&#13;&#10;THEN &apos;Rolling 1Yr&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column aggregation='Sum' caption='1st Yr End week (Rolling)' datatype='integer' name='[Calculation_2081788987456192526]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[Calculation_1003739781620453378]+100' />
      </column>
      <column caption='Drawers (13wk)' datatype='integer' name='[Calculation_2081788987457142800]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [13wk_max_vol]&gt;0 THEN 1&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Drop Off/' datatype='boolean' name='[Calculation_2081788987458228241]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='INT([iso_week]) = INT([Calculation_2081788987456192526])' />
      </column>
      <column caption='Account Status (Fuel)' datatype='integer' name='[Calculation_2081788987459231764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [fuel_live_account] = &apos;TRUE&apos; THEN 1&#13;&#10;ELSEIF [fuel_live_account] = &apos;FALSE&apos; THEN 0&#13;&#10;END' />
      </column>
      <column caption='Neverdrawn' datatype='integer' name='[Calculation_2081788987459293205]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF INT([first_trans_week]) = 0 &#13;&#10;OR INT([first_trans_week]) &gt; INT([iso_week]) &#13;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='New Buyers within 4 wks' datatype='integer' name='[Calculation_2081788987459731479]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1003739781612056576]=1 AND DATEDIFF(&apos;day&apos;,[start_date (Custom SQL Query)],[first_trans_date])&lt;=28&#13;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Unique App' datatype='string' name='[Calculation_2147935580801040384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([external_lead_id]) THEN [app_id] &#13;&#10;ELSE [external_lead_id] END' />
      </column>
      <column caption='App Completed ISOWeek' datatype='integer' name='[Calculation_2147935580801355777]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[date_app_completed])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [date_app_completed])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [date_app_completed])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='Accounts Created' datatype='integer' name='[Calculation_2147935580813082631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1003739781620453378] = int([iso_week]) THEN 1 ELSE 0 END' />
      </column>
      <column caption='New Buyers to Start Week' datatype='integer' name='[Calculation_2147935580815921161]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [surr_id],[iso_week]: MAX(IF [Calculation_2147935580813082631]=1 AND ({ EXCLUDE [iso_week]:SUM([volume])})&gt;0 THEN 1 END)}' />
      </column>
