                </bin>
                <bin default-name='false' value='&quot;Netherlands&quot;'>
                  <value>&quot;Fuel NL&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Portugal&quot;'>
                  <value>&quot;Fuel PT&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Singapore&quot;'>
