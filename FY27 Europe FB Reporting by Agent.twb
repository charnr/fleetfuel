	 ,live_card_count &#13;
FROM cust_reference</relation>
                </relation>
                <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 2)' name='trans detail' type='text'>SELECT&#13;
	 cust_surr_id&#13;
	,SUM(sum_quantity) AS sum_quantity_to_date&#13;
	,MIN(tran_date) AS earliest_tran&#13;
	,MAX(tran_date) AS latest_tran&#13;
	,trans_iso_country_code&#13;
--	,trans_product_name&#13;
FROM trans_detail_rolling&#13;
WHERE trans_product_name IN	(&apos;DIESEL&apos;,&apos;UNLEADED&apos;,&apos;PREMIUM DIESEL&apos;,&apos;PREMIUM UNLEADED&apos;,&apos;SUPER UNLEADED&apos;,&apos;BIO DIESEL&apos;,&apos;HVO&apos;,&apos;LNG&apos;,&apos;LPG&apos;,&apos;LRP&apos;,&apos;E-CHARGE FAST&apos;,&apos;E-CHARGE RAPID&apos;,&apos;E-CHARGE ULTRAFAST&apos;)&#13;
