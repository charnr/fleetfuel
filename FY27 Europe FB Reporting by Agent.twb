                          <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 2)' name='Sales ER' type='text'>SELECT active,&#13;
  cost_center,&#13;
  department,&#13;
  director,&#13;
  division,&#13;
 division_costs,&#13;
 division_mgmt,&#13;
 employee_id,&#13;
  employee_inactive,&#13;
  employment_record,&#13;
  employment_type,&#13;
  end_date,&#13;
  fte,&#13;
  function,&#13;
 group_division_costs,&#13;
 group_division_mgmt,&#13;
  job_title,&#13;
  legal_entity,&#13;
  manager,&#13;
  months_since_start,&#13;
 office_location,&#13;
  revenue_generating,&#13;
  role_center,&#13;
  start_date,&#13;
 team,&#13;
  team_member,&#13;
  team_member_first_preferred_name&#13;
FROM sage_people.employment_record&#13;
WHERE  division_mgmt = &apos;Fuel&apos;&#13;
AND  Department IN (&apos;Sales&apos;,&apos;Account Management&apos;)&#13;
AND  ( end_date &gt;&gt;= &apos;2025-04-01&apos; OR end_date IS NULL)</relation>
                          <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 2)' name='SF User' type='text'>SELECT&#13;
employee_id,&#13;
name&#13;
FROM salesforce.user</relation>
