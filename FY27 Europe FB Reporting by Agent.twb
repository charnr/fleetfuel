      <column caption='Volume From' datatype='date' name='[Calculation_185210593375223814]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISNULL([end_date]) THEN TODAY() ELSE DATE([end_date]) END' />
      </column>
      <column caption='Rolling 1Yr' datatype='string' name='[Calculation_185210593375666184]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date (Custom SQL Query)]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-52,[Calculation_185210593375223814]))&#13;&#10;THEN &apos;Rolling 1Yr&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='Rolling 52 wk' datatype='real' name='[Calculation_475974199311101954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_185210593375666184] = &quot;Rolling 1Yr&quot; THEN [volume]&#13;&#10;else NULL&#13;&#10;END' />
      </column>
      <column caption='Paycode (calc)' datatype='integer' name='[Calculation_490892419119345665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if &#13;&#10;[payment_terms (Custom SQL Query)] = 7 then 2 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 10 then 3 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 14 then 3 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 15 then 7 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 20 then 8 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 21 then 4 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 25 then 8 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 28 then 5 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 30 then 10 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 31 then 2 elseif&#13;&#10;[payment_terms (Custom SQL Query)] = 42 then 6 else&#13;&#10;1 end' />
      </column>
      <column caption='Credit Limit' datatype='integer' name='[Calculation_490892419119603714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(zn([gip])+zn([ncm])+zn([sign_off])+zn([deposit]))-int(right(str((zn([gip])+zn([ncm])+zn([sign_off])+zn([deposit]))),2))' />
      </column>
      <column caption='Weekly Credit Limit (Calc)' datatype='real' name='[Calculation_490892419119693827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_490892419119603714]/[Calculation_490892419119345665]' />
      </column>
      <column caption='Credit Limit (Drawers)' datatype='real' name='[Calculation_490892419119788036]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [drawing] = 1 THEN [Calculation_490892419119693827] END' />
      </column>
      <column caption='OSW' datatype='integer' name='[Calculation_490892419120254982]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[start_date (Custom SQL Query)])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date (Custom SQL Query)])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date (Custom SQL Query)])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='2nd Yr End Week (Rolling)' datatype='integer' name='[Calculation_490892419120349191]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([bb_transfer_week]) - 100' />
