            <connection authentication='auth-user-pass' class='redshift' dbname='radiusdw' odbc-connect-string-extras='' one-time-sql='' port='5439' schema='public' server='radius-datawarehouse-production.radius.com' show-other-databases='' single-node='' sslmode='require' username='leannespooner' />
