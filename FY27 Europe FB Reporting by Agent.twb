                      <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 2)' name='Custs' type='text'>SELECT&#13;
surr_id&#13;
,gip,ncm,sign_off, deposit, payment_terms, payment_terms_type, invoice_frequency&#13;
FROM public.customers</relation>
