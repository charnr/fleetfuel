                </bin>
                <bin default-name='false' value='&quot;UK&quot;'>
                  <value>&quot;Fuel UK&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Agent Name' datatype='string' name='[agent_name]' role='dimension' type='nominal' />
            <column datatype='string' name='[bb_transfer_week]' role='dimension' type='nominal' />
            <column datatype='integer' name='[deposit]' role='measure' type='quantitative' />
            <column datatype='integer' name='[drawing]' role='measure' type='quantitative' />
            <column caption='Employee Id' datatype='string' name='[employee_id]' role='dimension' type='nominal' />
