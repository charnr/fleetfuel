            </column>
            <column caption='Net Fuel Price' datatype='real' name='[Calculation_2081788987455135754]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [surr_id] : MAX(IF [country] = &apos;GB&apos;THEN 1.5&#13;&#10;ELSEIF [country] = &apos;IE&apos; THEN 1.5&#13;&#10;ELSEIF [country] = &apos;NL&apos; THEN 1.7&#13;&#10;ELSEIF [country] = &apos;BE&apos; THEN 1.7&#13;&#10;ELSEIF [country] = &apos;FR&apos; THEN 1.9&#13;&#10;ELSEIF [country] = &apos;PT&apos; then 1.9   &#13;&#10;ELSEIF [country] = &apos;ES&apos; THEN 2.1&#13;&#10;ELSEIF [country] = &apos;DE&apos; THEN 1.8&#13;&#10;ELSEIF [country] = &apos;IT&apos; THEN 2&#13;&#10;ELSEIF [country] = &apos;MY&apos; THEN 2.5&#13;&#10;ELSEIF [country] = &apos;SG&apos; THEN 1.8&#13;&#10;ELSE 0&#13;&#10;END)}' />
            </column>
            <column caption='Max Paycode Weeks Exposure' datatype='integer' name='[Calculation_2081788987455328267]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [surr_id] : MAX([paycode_weeks_exposure])}' />
            </column>
            <column caption='Max given fuel limit' datatype='integer' name='[Calculation_2081788987455389708]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [surr_id]: MAX([given_fuel_limit])}' />
            </column>
            <column caption='VOC New' datatype='real' name='[Calculation_2081788987455430669]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [surr_id]: MAX(IF [underwriting_type] =&apos;External Insurance&apos; THEN  (IFNULL([Calculation_2081788987454959624],0)+ IFNULL([Calculation_2081788987455057929],0)) / [Calculation_2081788987455135754] / [Calculation_2081788987455328267] * 4.33 &#13;&#10;ELSE (IFNULL([Calculation_2081788987455389708],0)+ IFNULL([Calculation_2081788987455057929],0)) / [Calculation_2081788987455135754] / [Calculation_2081788987455328267] * 4.33&#13;&#10;END)}' />
            </column>
            <column caption='App Completed ISOWeek' datatype='integer' name='[Calculation_2147935580801355777]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[date_app_completed])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [date_app_completed])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [date_app_completed])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
