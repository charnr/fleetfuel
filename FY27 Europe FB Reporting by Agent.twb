        <relation type='collection'>
          <relation join='left' type='join'>
            <clause type='join'>
              <expression op='='>
                <expression op='[Sales ER].[employee_id]' />
                <expression op='[SF User].[employee_id]' />
              </expression>
            </clause>
            <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 3)' name='Sales ER' type='text'>SELECT active,&#13;
  cost_center,&#13;
  department,&#13;
  director,&#13;
  division,&#13;
 division_costs,&#13;
 division_mgmt,&#13;
 employee_id,&#13;
  employee_inactive,&#13;
  employment_record,&#13;
  employment_type,&#13;
  end_date,&#13;
  fte,&#13;
  function,&#13;
 group_division_costs,&#13;
 group_division_mgmt,&#13;
  job_title,&#13;
  legal_entity,&#13;
  manager,&#13;
  months_since_start,&#13;
 office_location,&#13;
  revenue_generating,&#13;
  role_center,&#13;
  start_date,&#13;
 team,&#13;
  team_member,&#13;
  team_member_first_preferred_name&#13;
FROM sage_people.employment_record&#13;
WHERE  division_mgmt = &apos;Fuel&apos;&#13;
AND  division_costs = &apos;Fuel&apos;&#13;
AND  team IN (&apos;Sales IB&apos;,&apos;Sales OB&apos;,&apos;Sales Field&apos;,&apos;Sales OB (Key)&apos;)&#13;
AND  ( end_date &gt;&gt;= &apos;2025-04-01&apos; OR end_date IS NULL)</relation>
            <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 3)' name='SF User' type='text'>SELECT&#13;
employee_id,&#13;
name&#13;
FROM salesforce.user</relation>
          </relation>
          <relation join='left' type='join'>
            <clause type='join'>
              <expression op='='>
                <expression op='STR([Custs].[surr_id])' />
                <expression op='STR([Custom SQL Query].[cust_surr_id])' />
              </expression>
            </clause>
            <relation join='left' type='join'>
              <clause type='join'>
                <expression op='='>
                  <expression op='[salesforce_cruise_apps].[cust_surr_id]' />
                  <expression op='[Custs].[surr_id]' />
                </expression>
              </clause>
              <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 3)' name='salesforce_cruise_apps' table='[public].[salesforce_cruise_apps]' type='table' />
              <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 3)' name='Custs' type='text'>SELECT &#13;
	 surr_id,&#13;
        cust_type,&#13;
cust_name&#13;
	 ,start_date&#13;
	 ,country&#13;
	 ,cohort_country&#13;
    ,cohort_account_type&#13;
	 ,brand_no&#13;
	 ,cust_no&#13;
	 ,dist_company_no&#13;
,distributor&#13;
	 ,dist_no&#13;
	 ,sales_agent_name&#13;
FROM customers&#13;
Where cohort_account_type = &apos;PAYGO&apos;&#13;
AND start_date &gt;&gt;= &apos;2024-04-01&apos;</relation>
            </relation>
            <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 3)' name='Custom SQL Query' type='text'>SELECT * FROM (&#13;
select  sum(quantity) as Volume, cust_surr_id, iso_week, product_name,iso_no&#13;
from public.transactions tf&#13;
where deleted_date is null&#13;
and iso_week &gt;&gt;= &apos;202514&apos;&#13;
and product_name IN(&apos;DIESEL&apos;, &apos;UNLEADED&apos;, &apos;PREMIUM DIESEL&apos;,&#13;
&apos;PREMIUM UNLEADED&apos;, &apos;SUPER UNLEADED&apos;, &apos;LPG&apos;, &apos;HVO&apos;, &apos;BIO DIESEL&apos;,&apos;LNG&apos;,&apos;LRP&apos;, &apos;ELECTRIC CHARGING (KW/H)&apos;, &apos;E-CHARGE FAST&apos;, &apos;E-CHARGE RAPID&apos;, &apos;E-CHARGE ULTRAFAST&apos;)&#13;
group by cust_surr_id, iso_week, product_name, iso_no&#13;
) tf&#13;
LEFT OUTER JOIN (&#13;
	SELECT caldate, isowk::VARCHAR FROM calendar where DATE_PART(&apos;dow&apos;, caldate)= 6&#13;
) a  ON tf.iso_week = a.isowk</relation>
          </relation>
        </relation>
