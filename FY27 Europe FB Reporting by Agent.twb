          <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 4)' name='Vol' type='text'>SELECT * FROM (&#13;
select  quantity as Volume, cust_surr_id, product_name,iso_no,&#13;
&#13;
&#13;
  MIN(CASE WHEN iso_no&#13;
            = 789712 THEN tran_date END)&#13;
	  OVER (PARTITION BY cust_surr_id ORDER BY tran_date ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS first_radiusone_tran_date,&#13;
 &#13;
MIN(tran_date)&#13;
	  OVER (PARTITION BY cust_surr_id ORDER BY tran_date ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS first_tran_date&#13;
&#13;
from ext_sources.transactions_fuel_with_costs&#13;
where deleted_date is null&#13;
and product_name IN(&apos;DIESEL&apos;, &apos;UNLEADED&apos;, &apos;PREMIUM DIESEL&apos;,&#13;
&apos;PREMIUM UNLEADED&apos;, &apos;SUPER UNLEADED&apos;, &apos;LPG&apos;, &apos;HVO&apos;, &apos;BIO DIESEL&apos;,&apos;LNG&apos;,&apos;LRP&apos;, &apos;ELECTRIC CHARGING (KW/H)&apos;, &apos;E-CHARGE FAST&apos;, &apos;E-CHARGE RAPID&apos;, &apos;E-CHARGE ULTRAFAST&apos;)&#13;
) tfwc</relation>
