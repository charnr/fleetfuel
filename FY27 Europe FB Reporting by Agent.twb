      <aliases enabled='yes' />
      <column caption='New Buyer Detail' datatype='string' name='[Calculation_1729100824224149506]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATE([first_radiusone_tran_date]) = DATE([first_tran_date]) THEN &apos;RadiusOne&apos;&#13;&#10;ELSE &apos;Other&apos; END' />
      </column>
      <column aggregation='Sum' caption='First Tran Week' datatype='integer' name='[Calculation_1729100824225087491]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[first_tran_date])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [first_tran_date])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [first_tran_date])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='Volume From' datatype='date' name='[Calculation_185210593375223814]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISNULL([end_date]) THEN TODAY() ELSE DATE([end_date]) END' />
      </column>
      <column caption='Rolling 1Yr' datatype='string' name='[Calculation_185210593375666184]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date (Custom SQL Query)]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-52,[first_tran_date]))&#13;&#10;THEN &apos;Rolling 1Yr&apos;&#13;&#10;ELSEIF DATETRUNC(&apos;week&apos;,[start_date (Custom SQL Query)]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-52,[first_radiusone_tran_date]))&#13;&#10;THEN &apos;Rolling 1Yr&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='Rolling 52 wk' datatype='real' name='[Calculation_475974199311101954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_185210593375666184] = &quot;Rolling 1Yr&quot; THEN [volume]&#13;&#10;else NULL&#13;&#10;END' />
      </column>
