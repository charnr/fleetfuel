                    <relation connection='redshift.18pcf8c008wo7010thp281wxhxbc (copy 2)' name='Sales ER' type='text'>SELECT active,&#13;
  cost_center,&#13;
  department,&#13;
  director,&#13;
  division,&#13;
 division_costs,&#13;
 division_mgmt,&#13;
 employee_id,&#13;
  employee_inactive,&#13;
