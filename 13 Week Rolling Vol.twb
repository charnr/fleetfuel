      <aliases enabled='yes' />
      <column caption='26 Week Rolling' datatype='string' name='[13 Week Rolling (copy)_1009087853299793920]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-26,[caldate]))&#13;&#10;THEN &apos;Rolling 26 Week&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='13W Vol' datatype='real' name='[13 Week Rolling (copy)_1912622517257437184]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-13,[caldate]))&#13;&#10;THEN [volume]&#13;&#10;ELSE 0 END' />
      </column>
      <column caption='BB 13W Rolling EV' datatype='string' name='[13 Week Rolling (copy)_347340181790425097]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[Calculation_347340181790302215]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-13,[caldate]))&#13;&#10;THEN &apos;Rolling 13 Week EV&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='26W Drawers' datatype='real' name='[13W Drawers (copy)_1912622517260156933]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-26,[caldate]))&#13;&#10;THEN [Drawers (copy)_1912622517258641411]&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='13W Drawers' datatype='real' name='[13W Vol (copy)_1912622517258207234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-13,[caldate]))&#13;&#10;THEN [Drawers (copy)_1912622517258641411]&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='26W Vol' datatype='real' name='[13W Vol (copy)_1912622517260062724]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-26,[caldate]))&#13;&#10;THEN [volume]&#13;&#10;ELSE 0 END' />
      </column>
      <column caption='Office - Team Fix.' datatype='string' name='[Calculation_1261007952278413319]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [dist_no] = 593 then &apos;Ipswich - DT&apos; ELSE&#13;&#10;[Calculation_2229563356941492224] END' />
      </column>
      <column caption='Sales Agent Name Fix' datatype='string' name='[Calculation_168603567970664449]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [sales_agent_name] = &quot; KEELAN SWIFT STALLEY&quot; THEN &quot;Keelan Swift-Stalley&quot;&#13;&#10;ELSEIF STR([surr_id]) = [surr_id (front_book_fixes_volume_moves)] THEN [agent_to]&#13;&#10;ELSEIF [sales_agent_name] = [customers_agent_name] AND [start_date] &lt; [date_move] THEN [team_move_from]&#13;&#10;ELSEIF [agent_name] = NULL THEN [sales_agent_name]&#13;&#10;ELSEIF ISNULL([agent_name])THEN [sales_agent_name] ELSE [agent_name] END' />
      </column>
      <column caption='13 Week Rolling' datatype='string' name='[Calculation_168603567971426306]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-13,[caldate]))&#13;&#10;THEN &apos;Rolling 13 Week&apos;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='Tran Week' datatype='integer' name='[Calculation_168603567972519941]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[Calculation_168603567972462596])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [Calculation_168603567972462596])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [Calculation_168603567972462596])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='Drawers' datatype='integer' name='[Calculation_1781736638092660738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF { FIXED [cust_surr_id (Custom SQL Query)]: MAX([volume]) } &gt; 0&#13;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Average Volume per Drawer' datatype='real' name='[Calculation_1781736638094344195]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([volume])/SUM([Calculation_1781736638092660738])' />
      </column>
      <column aggregation='Sum' caption='Min Tran Date ISOWeek' datatype='integer' name='[Calculation_1851542434893656064]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[Calculation_347340181790302215])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [Calculation_347340181790302215])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [Calculation_347340181790302215])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='Office - Team' datatype='string' name='[Calculation_2229563356941492224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_168603567970664449] = &quot;Keelan Swift-Stalley&quot; THEN &quot;Ipswich - Fleet&quot;&#13;&#10;ELSEIF STR([cust_surr_id]) = STR([surr_id (front_book_fixes_volume_moves)]) THEN [team_to]&#13;&#10;ELSEIF UPPER([agent_name]) =UPPER([customers_agent_name]) AND [start_date] &lt; [date_move] THEN [team_move_from]&#13;&#10;ELSE [office_team] END' />
      </column>
      <column caption='Inc/Exc' datatype='string' name='[Calculation_347058713105281025]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_168603567970664449] IN (&quot;Glasgow - Fleet&quot;,&quot;Glasgow - Field&quot;,&quot;Glasgow - HGV&quot;,&quot;Ipswich - Fleet&quot;,&quot;Ipswich - HGV&quot;,&quot;Ipswich - Field&quot;,&quot;Crewe - Inbound&quot;,&quot;Crewe - Fleet&quot;,&quot;Crewe - Field&quot;,&quot;Crewe - HGV&quot;,&quot;York - Fleet&quot;,&quot;York - Field&quot;,&quot;York - HGV&quot;,&quot;JW - Inbound&quot;,&quot;Jav - Inbound&quot;,&quot;Seb - Inbound&quot;)&#13;&#10;Then &quot;Exclude&quot;&#13;&#10;ELSE &quot;Include&quot;&#13;&#10;END' />
      </column>
      <column caption='OSW' datatype='integer' name='[Calculation_347340181780873217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='int(&#13;&#10;str(datepart(&apos;year&apos;, dateadd(&apos;week&apos;, INT(datediff(&apos;day&apos;, #1900-1-1#,[start_date])/7), #1900-1-4#)))+ &#13;&#10;IF INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date])/7)*7  + 3,#1900-1-01#))) + 6)/7) &lt; 10 THEN&#13;&#10;    &apos;0&apos;&#13;&#10;ELSE&#13;&#10;    &apos;&apos;&#13;&#10;END +&#13;&#10;str(INT((Datepart(&apos;dayofyear&apos;, (dateadd(&apos;day&apos;,INT(datediff(&apos;day&apos;, #1900-1-01#, [start_date])/7)*7  + 3,#1900-1-01#))) + 6)/7))&#13;&#10;)' />
      </column>
      <column caption='Cohort (Rolling)' datatype='string' name='[Calculation_347340181781032963]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;week&apos;,[start_date],TODAY()) &lt;=52  THEN&#13;&#10;    &apos;1st Yr/FB&apos;&#13;&#10;ELSE &apos;BB&apos; END' />
      </column>
      <column caption='Min Tran Date' datatype='date' name='[Calculation_347340181790302215]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [cust_surr_id] : MIN ([caldate])}' />
      </column>
