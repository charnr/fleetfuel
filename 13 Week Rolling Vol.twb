                  </expression>
                </clause>
                <relation join='left' type='join'>
                  <clause type='join'>
                    <expression op='='>
                      <expression op='STR([customers].[surr_id])' />
                      <expression op='STR([live_allocations].[web_cust_id])' />
                    </expression>
                  </clause>
                  <relation join='left' type='join'>
                    <clause type='join'>
                      <expression op='='>
                        <expression op='[customers].[surr_id]' />
                        <expression op='[vol/gm].[cust_surr_id]' />
                      </expression>
                    </clause>
                    <relation join='left' type='join'>
                      <clause type='join'>
                        <expression op='='>
                          <expression op='[customers].[surr_id]' />
                          <expression op='[front_book_fixes_volume_moves].[surr_id]' />
                        </expression>
                      </clause>
                      <relation join='left' type='join'>
                        <clause type='join'>
                          <expression op='='>
                            <expression op='[customers].[sales_agent_name]' />
                            <expression op='[front_book_fixes_agent_matrix].[customers_agent_name]' />
                          </expression>
                        </clause>
                        <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='customers' type='text'>select sales_agent_name, cohort_country, start_date, surr_id, cust_name, dist_no, product_name, cust_type, business_type&#13;
from customers</relation>
                        <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='front_book_fixes_agent_matrix' table='[fuel].[front_book_fixes_agent_matrix]' type='table' />
