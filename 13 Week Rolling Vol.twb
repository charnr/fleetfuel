          <named-connection caption='radius-datawarehouse-production.radius.com' name='redshift.05ex8lu19j7rpq1cq3a590i82jiv'>
            <connection authentication='auth-user-pass' class='redshift' dbname='radiusdw' odbc-connect-string-extras='' one-time-sql='' port='5439' schema='fuel' server='radius-datawarehouse-production.radius.com' server-oauth='' server-userid='820662' show-other-databases='' single-node='' sslmode='require' username='charnroberts' workgroup-auth-mode='prompt' />
          </named-connection>
        </named-connections>
        <relation join='left' type='join'>
          <clause type='join'>
            <expression op='='>
              <expression op='[customers].[surr_id]' />
              <expression op='[Custom SQL Query].[cust_surr_id]' />
            </expression>
          </clause>
          <relation join='left' type='join'>
            <clause type='join'>
              <expression op='='>
                <expression op='STR([customers].[surr_id])' />
                <expression op='STR([live_allocations].[web_cust_id])' />
              </expression>
            </clause>
            <relation join='left' type='join'>
              <clause type='join'>
                <expression op='='>
                  <expression op='[customers].[surr_id]' />
                  <expression op='[vol/gm].[cust_surr_id]' />
                </expression>
              </clause>
              <relation join='left' type='join'>
                <clause type='join'>
                  <expression op='='>
                    <expression op='[customers].[surr_id]' />
                    <expression op='[front_book_fixes_volume_moves].[surr_id]' />
                  </expression>
                </clause>
                <relation join='left' type='join'>
                  <clause type='join'>
                    <expression op='='>
                      <expression op='[customers].[sales_agent_name]' />
                      <expression op='[front_book_fixes_agent_matrix].[customers_agent_name]' />
                    </expression>
                  </clause>
                  <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='customers' type='text'>select sales_agent_name, cohort_country, start_date, surr_id, cust_name, dist_no, product_name, cust_type, business_type&#13;
from customers</relation>
                  <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='front_book_fixes_agent_matrix' table='[fuel].[front_book_fixes_agent_matrix]' type='table' />
                </relation>
                <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='front_book_fixes_volume_moves' table='[fuel].[front_book_fixes_volume_moves]' type='table' />
              </relation>
              <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='vol/gm' type='text'>SELECT * FROM (&#13;
select  sum(quantity) as Volume, cust_surr_id, iso_week, product_name&#13;
from ext_sources.transactions_fuel_with_costs&#13;
where deleted_date is null&#13;
and iso_week &gt;&gt;= &apos;202614&apos;&#13;
and product_name IN(&apos;AD BLUE&apos;,&apos;DIESEL&apos;, &apos;UNLEADED&apos;, &apos;PREMIUM DIESEL&apos;,&#13;
&apos;PREMIUM UNLEADED&apos;, &apos;SUPER UNLEADED&apos;, &apos;LPG&apos;, &apos;HVO&apos;, &apos;BIO DIESEL&apos;,&apos;LNG&apos;,&apos;LRP&apos;, &apos;ELECTRIC CHARGING (KW/H)&apos;, &apos;E-CHARGE FAST&apos;, &apos;E-CHARGE RAPID&apos;, &apos;E-CHARGE ULTRAFAST&apos;)&#13;
group by cust_surr_id, iso_week, product_name&#13;
) tfwc&#13;
LEFT OUTER JOIN (&#13;
	SELECT MAX(caldate) AS caldate, isowk::VARCHAR AS isowk FROM calendar where DATE_PART(&apos;dow&apos;, caldate)= 6 GROUP BY isowk::VARCHAR&#13;
) a  ON tfwc.iso_week = a.isowk</relation>
            </relation>
            <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='live_allocations' table='[fuel_dw].[live_allocations]' type='table' />
          </relation>
          <relation connection='redshift.05ex8lu19j7rpq1cq3a590i82jiv' name='Custom SQL Query' type='text'>SELECT &#13;
lead_channel AS Lead_Channel,&#13;
cust_surr_id&#13;
FROM salesforce_cruise_apps&#13;
LEFT JOIN public.customers&#13;
ON &#13;
surr_id = cust_surr_id</relation>
        </relation>
