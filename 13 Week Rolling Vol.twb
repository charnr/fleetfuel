              <calculation class='tableau' formula='IF  [dist_no] = 593 then &apos;Ipswich - DT&apos; ELSE&#13;&#10;[Calculation_2229563356941492224] END' />
            </column>
            <column caption='Sales Agent Name Fix' datatype='string' name='[Calculation_168603567970664449]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [sales_agent_name] = &quot; KEELAN SWIFT STALLEY&quot; THEN &quot;Keelan Swift-Stalley&quot;&#13;&#10;ELSEIF STR([surr_id]) = [surr_id (front_book_fixes_volume_moves)] THEN [agent_to]&#13;&#10;ELSEIF [sales_agent_name] = [customers_agent_name] AND [start_date] &lt; [date_move] THEN [team_move_from]&#13;&#10;ELSEIF [agent_name] = NULL THEN [sales_agent_name]&#13;&#10;ELSEIF ISNULL([agent_name])THEN [sales_agent_name] ELSE [agent_name] END' />
            </column>
            <column caption='13 Week Rolling' datatype='string' name='[Calculation_168603567971426306]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATETRUNC(&apos;week&apos;,[start_date]) &gt; DATETRUNC(&apos;week&apos;,DATEADD(&apos;week&apos;,-13,[caldate]))&#13;&#10;THEN &apos;Rolling 13 Week&apos;&#13;&#10;ELSE NULL END' />
            </column>
            <column caption='Office - Team' datatype='string' name='[Calculation_2229563356941492224]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_168603567970664449] = &quot;Keelan Swift-Stalley&quot; THEN &quot;Ipswich - Fleet&quot;&#13;&#10;ELSEIF STR([cust_surr_id]) = STR([surr_id (front_book_fixes_volume_moves)]) THEN [team_to]&#13;&#10;ELSEIF UPPER([agent_name]) =UPPER([customers_agent_name]) AND [start_date] &lt; [date_move] THEN [team_move_from]&#13;&#10;ELSE [office_team] END' />
            </column>
